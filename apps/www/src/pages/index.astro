---
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>0xSlots — Collectively Owned Slots</title>
  <meta name="description" content="Harberger-taxed slots on Base. Self-assess, occupy, earn." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #ffffff;
      --surface: #fafafa;
      --border: #e5e5e5;
      --text: #0a0a0a;
      --muted: #737373;
      --accent: #a78bfa;
      --accent-fg: #0a0a0a;
      --accent-dim: rgba(167, 139, 250, 0.08);
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .container {
      max-width: 640px;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2.5rem;
    }

    .badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      color: #7c3aed;
      background: var(--accent-dim);
      border: 1px solid rgba(167, 139, 250, 0.2);
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      letter-spacing: 0.02em;
    }

    h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      text-align: center;
      color: var(--text);
    }

    .description {
      font-size: 1.125rem;
      color: var(--muted);
      text-align: center;
      line-height: 1.6;
      max-width: 480px;
    }

    .links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .link-primary {
      background: var(--text);
      color: var(--bg);
    }
    .link-primary:hover {
      opacity: 0.85;
      transform: translateY(-1px);
    }

    .link-secondary {
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .link-secondary:hover {
      border-color: var(--muted);
      transform: translateY(-1px);
    }

    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      width: 100%;
    }

    .feature {
      background: var(--surface);
      padding: 1.25rem;
      text-align: center;
    }

    .feature-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.5rem;
    }

    .feature-value {
      font-size: 0.95rem;
      font-weight: 600;
    }

    .install {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.75rem 1.25rem;
      border-radius: 8px;
      user-select: all;
    }

    .install span {
      color: #7c3aed;
    }

    footer {
      margin-top: 3rem;
      font-size: 0.75rem;
      color: var(--muted);
    }

    footer a {
      color: var(--muted);
      text-decoration: none;
    }
    footer a:hover {
      color: var(--text);
    }

    @media (max-width: 480px) {
      .features {
        grid-template-columns: 1fr;
      }
      .links {
        flex-direction: column;
        width: 100%;
      }
      .link {
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="badge">Partial Common Ownership</div>

    <h1>0xSlots</h1>

    <p class="description">
      Harberger-taxed slots on Base. Self-assess a price, pay continuous tax, get force-bought. One slot = one contract.
    </p>

    <div class="links">
      <a href="https://app.0xslots.org" class="link link-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Explorer
      </a>
      <a href="https://docs.0xslots.org" class="link link-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Docs
      </a>
      <a href="https://github.com/adcommune/0xSlots" class="link link-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <div class="features">
      <div class="feature">
        <div class="feature-label">Network</div>
        <div class="feature-value">Base</div>
      </div>
      <div class="feature">
        <div class="feature-label">Architecture</div>
        <div class="feature-value">1 Slot = 1 Contract</div>
      </div>
      <div class="feature">
        <div class="feature-label">Tax Model</div>
        <div class="feature-value">Harberger</div>
      </div>
    </div>

    <div class="install"><span>pnpm add</span> @0xslots/sdk @0xslots/contracts</div>

    <footer>
      Built by <a href="https://github.com/nezz0746">nezz</a>
    </footer>
  </div>
</body>
</html>
