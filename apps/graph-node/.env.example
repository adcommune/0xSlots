# Postgres — easiest is the Railway Postgres addon, then reference its vars:
#   postgres_host=${{Postgres.PGHOST}}
#   postgres_user=${{Postgres.PGUSER}}
#   postgres_pass=${{Postgres.PGPASSWORD}}
#   postgres_db=${{Postgres.PGDATABASE}}
#   postgres_port=${{Postgres.PGPORT}}
postgres_host=
postgres_user=
postgres_pass=
postgres_db=
postgres_port=5432

# IPFS — host:port of an IPFS node (no scheme). On Railway, deploy an
# ipfs/kubo service and use private networking:
#   ipfs=${{IPFS.RAILWAY_PRIVATE_DOMAIN}}:5001
ipfs=

# Ethereum networks. Format: "<network> <RPC URL>", space-separated for multi-network.
# IMPORTANT: do NOT use https://sepolia.base.org — its eth_getLogs is broken
# for some contracts. Use publicnode / tenderly / alchemy instead.
ethereum=base-sepolia:https://base-sepolia.publicnode.com base:https://base.publicnode.com

# Logging
GRAPH_LOG=info

# Reorg / finality (lower = faster sync, fine for L2s)
ETHEREUM_REORG_THRESHOLD=1
ETHEREUM_ANCESTOR_COUNT=1
