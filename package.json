{
  "name": "pco-protocol",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:landing": "turbo dev --filter=landing",
    "dev:mcp": "turbo dev --filter=@0xslots/mcp",
    "dev:nft": "turbo dev --filter=nft",
    "dev:all": "turbo dev --filter=landing --filter=@0xslots/mcp",
    "build:landing": "turbo build --filter=landing",
    "start:landing": "turbo start --filter=landing",
    "build:adland": "turbo build --filter=adland",
    "start:adland": "turbo start --filter=adland",
    "build:api": "turbo build --filter=api",
    "start:api": "turbo start --filter=api",
    "lint": "turbo lint",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=@0xslots/contracts --filter=@0xslots/sdk --filter=@adland/data --filter=@adland/react && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@changesets/cli": "^2.29.8",
    "turbo": "^2.8.20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "wagmi": "$wagmi",
      "@wagmi/core": "$@wagmi/core",
      "viem": "$viem",
      "react": "$react",
      "react-dom": "$react-dom",
      "@tanstack/react-query": "$@tanstack/react-query",
      "graphql-request": "$graphql-request",
      "graphql": "$graphql"
    }
  },
  "dependencies": {
    "wagmi": "3.5.0",
    "@wagmi/core": "3.4.0",
    "viem": "2.47.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@tanstack/react-query": "5.90.21",
    "graphql-request": "7.4.0",
    "graphql": "16.11.0"
  }
}
