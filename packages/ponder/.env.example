# Alchemy API key — used for both base-sepolia and base mainnet.
# (NOT https://sepolia.base.org — its eth_getLogs is broken for some contracts.)
# Get a free key at https://dashboard.alchemy.com/
ALCHEMY_API_KEY=

# Optional: Postgres for production. If omitted, Ponder uses local SQLite (.ponder/).
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Port for the GraphQL/HTTP server (default 42069)
PORT=42069
