{
  "name": "@0xslots/subgraph",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare:base-sepolia": "mustache config/base-sepolia.json subgraph.template.yaml > subgraph.yaml",
    "codegen": "graph codegen",
    "build": "graph codegen && graph build",
    "build:base-sepolia": "pnpm prepare:base-sepolia && pnpm build",
    "deploy:base-sepolia": "pnpm build:base-sepolia && graph deploy --studio $(node -p \"require('./config/base-sepolia.json').studioName\")",
    "create:local": "graph create --node http://localhost:8020/ 0xslots",
    "deploy:local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 0xslots"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.38.0"
  },
  "devDependencies": {
    "mustache": "^4.2.0"
  }
}
