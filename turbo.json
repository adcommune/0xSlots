{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "out/**", "dist/**"],
      "passThroughEnv": [
        "ALCHEMY_KEY",
        "FARCASTER_API_KEY",
        "NEYNAR_API_KEY",
        "PINATA_JWT",
        "UMAMI_WEBSITE_ID"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ALCHEMY_KEY",
        "FARCASTER_API_KEY",
        "NEYNAR_API_KEY",
        "PINATA_JWT",
        "UMAMI_WEBSITE_ID"
      ]
    },
    "lint": {}
  }
}
